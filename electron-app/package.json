{
  "name": "pip-mascot",
  "version": "2.0.0",
  "description": "Pip 🐾 — a Claude-usage-aware desktop mascot (Electron cross-platform port)",
  "main": "main.js",
  "author": {
    "name": "avisre",
    "email": "avinashsreekumar007@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/avisre/pip-mascot",
  "scripts": {
    "start": "electron .",
    "start:dev": "electron --enable-logging .",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.nous.pip-mascot",
    "productName": "Pip",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility",
      "icon": "build/icon.png",
      "executableName": "pip",
      "executableArgs": ["--no-sandbox"],
      "synopsis": "A Claude-usage-aware desktop mascot",
      "description": "Pip is a transparent, always-on-top character that walks along the bottom of your screen and changes mood based on your live Claude Code usage.",
      "desktop": {
        "StartupWMClass": "Pip"
      }
    },
    "win": {
      "target": ["nsis"]
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.utilities"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
